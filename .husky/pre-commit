#!/bin/sh
# .husky/pre-commit
# Design system enforcement hook
# Runs design-system linting on staged files before commit

set -e

# Only run if there are staged TypeScript/TSX files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(tsx?|jsx?)$' || true)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "🎨 Checking design system compliance for staged files..."

# Run design-system lint on staged files only
npx eslint $STAGED_FILES --rule 'design-system/*: error' 2>&1

if [ $? -eq 0 ]; then
  echo "✅ Design system checks passed"
  exit 0
else
  echo "❌ Design system violations found. Fix them and try again."
  exit 1
fi
